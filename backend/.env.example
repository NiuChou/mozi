# 复制为 .env.local (不入仓) 并填入 key。缺 key 的模型自动走 mock (零外呼)。
# 用法: source backend/.env.local 后重启后端。

# 国产模型 (信创级可用)
GLM_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
ARK_API_KEY=              # 火山方舟 (Volcengine Ark): DeepSeek-V4-Pro(1M) + 豆包 Seed 推理模型

# 全球模型 (HK 主体凭证)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 遥测 (可选)
POSTHOG_KEY=

# 运行模式: 1=本地优先(缺 key 走 mock, 零外呼) 0=云端
MOZI_LOCAL_FIRST=1
